{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DevBox",
  "version": "0.1.0",
  "identifier": "com.meqln.devbox",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "DevBox · 开发工具箱",
        "width": 1150,
        "height": 850,
        "minWidth": 1150,
        "minHeight": 850,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "MeQln",
    "icon": [
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true,
        "installMode": "both"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
